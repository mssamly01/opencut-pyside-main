@@ -0,0 +1,167 @@
+from __future__ import annotations
+
+from app.controllers.timeline_controller import TimelineController
+from app.domain.clips.base_clip import BaseClip
+from app.domain.clips.image_clip import ImageClip
+from app.domain.clips.video_clip import VideoClip
+from app.ui.inspector._inspector_base import block_signals
+from PySide6.QtCore import Qt
+from PySide6.QtWidgets import (
+    QComboBox,
+    QFormLayout,
+    QLabel,
+    QSlider,
+    QVBoxLayout,
+    QWidget,
+)
+
+COLOR_PRESETS: list[tuple[str, str]] = [
+    ("none", "None"),
+    ("warm", "Warm"),
+    ("cool", "Cool"),
+    ("sepia", "Sepia"),
+    ("bw", "Black & White"),
+    ("vivid", "Vivid"),
+]
+
+
+class _AdjustSlider(QSlider):
+    """Slider representing a -1.0..1.0 or 0..1 normalized value.
+
+    Stores values as integers (-100..100) internally for QSlider compatibility.
+    """
+
+    def __init__(self, value_range: tuple[float, float], parent: QWidget | None = None) -> None:
+        super().__init__(Qt.Orientation.Horizontal, parent)
+        self._value_min, self._value_max = value_range
+        span = int((self._value_max - self._value_min) * 100)
+        self.setRange(0, span)
+        self.setSingleStep(1)
+        self.setPageStep(5)
+
+    def set_normalized(self, value: float) -> None:
+        clamped = max(self._value_min, min(self._value_max, value))
+        self.setValue(int(round((clamped - self._value_min) * 100)))
+
+    def normalized_value(self) -> float:
+        return self._value_min + self.value() / 100.0
+
+
+class AdjustInspector(QWidget):
+    """Inspector tab exposing per-clip color adjustments.
+
+    Supports VideoClip and ImageClip (text adjustments are skipped since the
+    text inspector already controls color/outline/background).
+    """
+
+    def __init__(
+        self,
+        timeline_controller: TimelineController,
+        clip: BaseClip | None,
+        parent: QWidget | None = None,
+    ) -> None:
+        super().__init__(parent)
+        self._timeline_controller = timeline_controller
+        self._clip: BaseClip | None = clip
+
+        root = QVBoxLayout(self)
+        form = QFormLayout()
+        form.setFieldGrowthPolicy(QFormLayout.FieldGrowthPolicy.AllNonFixedFieldsGrow)
+
+        self._preset_combo = QComboBox(self)
+        for key, label in COLOR_PRESETS:
+            self._preset_combo.addItem(label, key)
+        self._preset_combo.currentIndexChanged.connect(self._on_preset_changed)
+        form.addRow("Color preset", self._preset_combo)
+
+        self._brightness = _AdjustSlider((-1.0, 1.0), self)
+        self._brightness.valueChanged.connect(self._commit_adjustments)
+        form.addRow("Brightness", self._brightness)
+
+        self._contrast = _AdjustSlider((-1.0, 1.0), self)
+        self._contrast.valueChanged.connect(self._commit_adjustments)
+        form.addRow("Contrast", self._contrast)
+
+        self._saturation = _AdjustSlider((-1.0, 1.0), self)
+        self._saturation.valueChanged.connect(self._commit_adjustments)
+        form.addRow("Saturation", self._saturation)
+
+        self._blur = _AdjustSlider((0.0, 1.0), self)
+        self._blur.valueChanged.connect(self._commit_adjustments)
+        form.addRow("Blur", self._blur)
+
+        root.addLayout(form)
+
+        self._hint = QLabel(
+            "Brightness / contrast / saturation range from -1 to +1. "
+            "Blur ranges 0 to 1 (max ~ 20px sigma on export).",
+            self,
+        )
+        self._hint.setWordWrap(True)
+        self._hint.setStyleSheet("color: #6d7684; font-size: 11px;")
+        root.addWidget(self._hint)
+        root.addStretch(1)
+
+        self.refresh_from_clip()
+
+    def set_clip(self, clip: BaseClip | None) -> None:
+        self._clip = clip
+        self.refresh_from_clip()
+
+    def refresh_from_clip(self) -> None:
+        clip = self._clip
+        supported = isinstance(clip, (VideoClip, ImageClip))
+        self.setEnabled(supported)
+        if not supported:
+            return
+        with block_signals(
+            self._preset_combo, self._brightness, self._contrast, self._saturation, self._blur
+        ):
+            preset = getattr(clip, "color_preset", "none")
+            idx = self._preset_combo.findData(preset)
+            self._preset_combo.setCurrentIndex(idx if idx >= 0 else 0)
+            self._brightness.set_normalized(float(getattr(clip, "brightness", 0.0)))
+            self._contrast.set_normalized(float(getattr(clip, "contrast", 0.0)))
+            self._saturation.set_normalized(float(getattr(clip, "saturation", 0.0)))
+            self._blur.set_normalized(float(getattr(clip, "blur", 0.0)))
+
+    def _commit_adjustments(self) -> None:
+        clip = self._clip
+        if not isinstance(clip, (VideoClip, ImageClip)):
+            return
+        self._timeline_controller.set_clip_adjustment(
+            clip.clip_id,
+            brightness=self._brightness.normalized_value(),
+            contrast=self._contrast.normalized_value(),
+            saturation=self._saturation.normalized_value(),
+            blur=self._blur.normalized_value(),
+        )
+
+    def _on_preset_changed(self, _index: int) -> None:
+        clip = self._clip
+        if not isinstance(clip, (VideoClip, ImageClip)):
+            return
+        preset_key = self._preset_combo.currentData()
+        brightness, contrast, saturation = PRESET_VALUES.get(preset_key, (0.0, 0.0, 0.0))
+        self._timeline_controller.set_clip_adjustment(
+            clip.clip_id,
+            color_preset=preset_key,
+            brightness=brightness,
+            contrast=contrast,
+            saturation=saturation,
+        )
+        with block_signals(self._brightness, self._contrast, self._saturation):
+            self._brightness.set_normalized(brightness)
+            self._contrast.set_normalized(contrast)
+            self._saturation.set_normalized(saturation)
+
+
+# (key, (brightness, contrast, saturation)) — neutral 0 values mean unchanged.
+PRESET_VALUES: dict[str, tuple[float, float, float]] = {
+    "none": (0.0, 0.0, 0.0),
+    "warm": (0.10, 0.05, 0.20),
+    "cool": (-0.05, 0.05, -0.10),
+    "sepia": (0.05, 0.10, -0.60),
+    "bw": (0.0, 0.15, -1.0),
+    "vivid": (0.05, 0.25, 0.40),
+}

