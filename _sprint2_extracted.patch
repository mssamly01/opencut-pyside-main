+++ b/ui/effects_drawer.py
@@ -0,0 +1,169 @@
+from __future__ import annotations
+
+from app.controllers.app_controller import AppController
+from app.domain.clips.image_clip import ImageClip
+from app.domain.clips.video_clip import VideoClip
+from app.ui.inspector.adjust_inspector import COLOR_PRESETS, PRESET_VALUES
+from PySide6.QtCore import Qt
+from PySide6.QtWidgets import (
+    QFrame,
+    QGridLayout,
+    QHBoxLayout,
+    QLabel,
+    QPushButton,
+    QSlider,
+    QVBoxLayout,
+    QWidget,
+)
+
+
+class EffectsDrawer(QWidget):
+    """Sprint 2 effects drawer.
+
+    A docked widget that exposes one-click color recipes plus a vignette
+    slider for the currently selected video / image clip. Sliders + buttons
+    delegate to ``timeline_controller.set_clip_adjustment`` so the changes
+    flow through the undo stack like every other clip edit.
+    """
+
+    def __init__(self, app_controller: AppController, parent: QWidget | None = None) -> None:
+        super().__init__(parent)
+        self._app_controller = app_controller
+
+        root = QVBoxLayout(self)
+        root.setContentsMargins(8, 8, 8, 8)
+        root.setSpacing(8)
+
+        self._status_label = QLabel("Select a video or image clip to apply effects.", self)
+        self._status_label.setWordWrap(True)
+        self._status_label.setStyleSheet("color: #6d7684; font-size: 12px;")
+        root.addWidget(self._status_label)
+
+        # Color preset grid -------------------------------------------------
+        preset_label = QLabel("Color preset", self)
+        preset_label.setStyleSheet("font-weight: bold;")
+        root.addWidget(preset_label)
+
+        preset_grid = QGridLayout()
+        preset_grid.setHorizontalSpacing(6)
+        preset_grid.setVerticalSpacing(6)
+        self._preset_buttons: list[QPushButton] = []
+        for index, (key, label) in enumerate(COLOR_PRESETS):
+            button = QPushButton(label, self)
+            button.setProperty("preset_key", key)
+            button.setCheckable(True)
+            button.setCursor(Qt.CursorShape.PointingHandCursor)
+            button.clicked.connect(
+                lambda _checked, preset=key: self._apply_preset(preset)
+            )
+            preset_grid.addWidget(button, index // 3, index % 3)
+            self._preset_buttons.append(button)
+        root.addLayout(preset_grid)
+
+        divider = QFrame(self)
+        divider.setFrameShape(QFrame.Shape.HLine)
+        divider.setFrameShadow(QFrame.Shadow.Sunken)
+        root.addWidget(divider)
+
+        # Vignette + blur sliders -----------------------------------------
+        sliders_label = QLabel("Vignette / blur", self)
+        sliders_label.setStyleSheet("font-weight: bold;")
+        root.addWidget(sliders_label)
+
+        self._blur_slider = self._make_slider("Blur", root)
+        self._blur_slider.valueChanged.connect(
+            lambda v: self._apply_adjustment(blur=v / 100.0)
+        )
+
+        self._vignette_slider = self._make_slider("Vignette", root)
+        self._vignette_slider.valueChanged.connect(
+            lambda v: self._apply_adjustment(vignette=v / 100.0)
+        )
+
+        root.addStretch(1)
+
+        self._app_controller.selection_controller.selection_changed.connect(self._refresh)
+        self._app_controller.timeline_controller.timeline_edited.connect(self._refresh)
+        self._refresh()
+
+    # --- Helpers --------------------------------------------------------
+    def _make_slider(self, label: str, parent_layout: QVBoxLayout) -> QSlider:
+        row = QHBoxLayout()
+        text = QLabel(label, self)
+        text.setMinimumWidth(72)
+        slider = QSlider(Qt.Orientation.Horizontal, self)
+        slider.setRange(0, 100)
+        slider.setSingleStep(1)
+        slider.setPageStep(5)
+        row.addWidget(text)
+        row.addWidget(slider, 1)
+        parent_layout.addLayout(row)
+        return slider
+
+    def _selected_clip(self):
+        clip_id = self._app_controller.selection_controller.selected_clip_id()
+        if clip_id is None:
+            return None
+        project = self._app_controller.project_controller.active_project()
+        if project is None:
+            return None
+        for track in project.timeline.tracks:
+            for clip in track.clips:
+                if clip.clip_id == clip_id and isinstance(clip, (VideoClip, ImageClip)):
+                    return clip
+        return None
+
+    def _refresh(self) -> None:
+        clip = self._selected_clip()
+        enabled = clip is not None
+        for widget in (
+            *self._preset_buttons,
+            self._blur_slider,
+            self._vignette_slider,
+        ):
+            widget.setEnabled(enabled)
+
+        if clip is None:
+            self._status_label.setText("Select a video or image clip to apply effects.")
+            for button in self._preset_buttons:
+                button.setChecked(False)
+            self._blur_slider.blockSignals(True)
+            self._vignette_slider.blockSignals(True)
+            self._blur_slider.setValue(0)
+            self._vignette_slider.setValue(0)
+            self._blur_slider.blockSignals(False)
+            self._vignette_slider.blockSignals(False)
+            return
+
+        self._status_label.setText(f"Effects: clip {clip.clip_id[:8]}…")
+
+        active_preset = getattr(clip, "color_preset", "none")
+        for button in self._preset_buttons:
+            button.setChecked(button.property("preset_key") == active_preset)
+
+        self._blur_slider.blockSignals(True)
+        self._vignette_slider.blockSignals(True)
+        self._blur_slider.setValue(int(round(float(getattr(clip, "blur", 0.0)) * 100)))
+        self._vignette_slider.setValue(int(round(float(getattr(clip, "vignette", 0.0)) * 100)))
+        self._blur_slider.blockSignals(False)
+        self._vignette_slider.blockSignals(False)
+
+    # --- Apply ----------------------------------------------------------
+    def _apply_preset(self, preset_key: str) -> None:
+        clip = self._selected_clip()
+        if clip is None:
+            return
+        brightness, contrast, saturation = PRESET_VALUES.get(preset_key, (0.0, 0.0, 0.0))
+        self._app_controller.timeline_controller.set_clip_adjustment(
+            clip.clip_id,
+            color_preset=preset_key,
+            brightness=brightness,
+            contrast=contrast,
+            saturation=saturation,
+        )
+
+    def _apply_adjustment(self, **fields: float) -> None:
+        clip = self._selected_clip()
+        if clip is None:
+            return
+        self._app_controller.timeline_controller.set_clip_adjustment(clip.clip_id, **fields)

diff --git a/ui/inspector/adjust_inspector.py b/ui/inspector/adjust_inspector.py
