+    )
+    refreshed = next(
+        c for t in project.timeline.tracks for c in t.clips if c.clip_id == clip.clip_id
+    )
+    # Position clamped to [-2, 3], scale to [0.05, 8.0], rotation wrapped to (-180, 180].
+    assert -2.0 <= refreshed.position_x <= 3.0
+    assert -2.0 <= refreshed.position_y <= 3.0
+    assert 0.05 <= refreshed.scale <= 8.0
+    assert -180.0 <= refreshed.rotation <= 180.0
