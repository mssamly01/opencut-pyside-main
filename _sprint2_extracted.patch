+            # 1.0. Map contrast [-1,1] → [0.0, 2.0]; saturation [-1,1] → [0, 2].
+            eq_contrast = max(0.0, 1.0 + contrast)
+            eq_saturation = max(0.0, 1.0 + saturation)
+            filters.append(
+                f"eq=brightness={brightness:.4f}:contrast={eq_contrast:.4f}:saturation={eq_saturation:.4f}"
+            )
+        if blur > 1e-3:
+            # Map blur 0..1 → sigma 0..20 px for a softer / heavier blur.
+            sigma = 0.1 + blur * 20.0
+            filters.append(f"gblur=sigma={sigma:.3f}")
+        vignette = float(getattr(clip, "vignette", 0.0) or 0.0)
+        if vignette > 1e-3:
+            # FFmpeg vignette filter angle in radians; PI/5 ≈ 36° default.
+            angle = 0.6 + vignette * 0.8  # 0.6..1.4 radians
+            filters.append(f"vignette=angle={angle:.4f}")
+        return filters
+
+    def _transform_filters(self, clip: BaseClip, project_width: int, project_height: int) -> list[str]:
+        filters: list[str] = []
+        rotation = float(getattr(clip, "rotation", 0.0) or 0.0)
+        scale_factor = float(getattr(clip, "scale", 1.0) or 1.0)
+        position_x = float(getattr(clip, "position_x", 0.5) or 0.5)
+        position_y = float(getattr(clip, "position_y", 0.5) or 0.5)
+
+        if abs(scale_factor - 1.0) > 1e-3:
+            scaled_w = max(2, int(round(project_width * scale_factor)))
+            scaled_h = max(2, int(round(project_height * scale_factor)))
+            filters.append(f"scale={scaled_w}:{scaled_h}:flags=bicubic")
+            filters.append(
+                f"crop=w='min(iw,{project_width})':h='min(ih,{project_height})':x='(iw-ow)/2':y='(ih-oh)/2'"
+            )
+            filters.append(
+                f"pad={project_width}:{project_height}:(ow-iw)/2:(oh-ih)/2:color=#00000000"
+            )
+
+        if abs(rotation) > 1e-3:
+            radians = rotation * 3.141592653589793 / 180.0
+            filters.append(
+                f"rotate={radians:.6f}:ow={project_width}:oh={project_height}:c=none"
+            )
+
+        if abs(position_x - 0.5) > 1e-3 or abs(position_y - 0.5) > 1e-3:
+            dx = int(round((position_x - 0.5) * project_width))
+            dy = int(round((position_y - 0.5) * project_height))
+            # Grow canvas by (dx,dy) so we don't lose pixels, then crop back to
+            # the original project dimensions with the shifted origin.
+            filters.append(
+                f"pad=w={project_width}:h={project_height}:x={max(0, dx)}:y={max(0, dy)}:color=#00000000"
+            )
+            filters.append(
+                f"crop=w={project_width}:h={project_height}:x={max(0, -dx)}:y={max(0, -dy)}"
+            )
+        return filters
+
