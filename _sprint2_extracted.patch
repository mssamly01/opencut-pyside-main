diff --git a/ui/dialogs/export_dialog.py b/ui/dialogs/export_dialog.py
new file mode 100644
index 0000000..fc7fded
--- /dev/null
+++ b/ui/dialogs/export_dialog.py
@@ -0,0 +1,276 @@
+from __future__ import annotations
+
+from pathlib import Path
+
+from app.domain.project import Project
+from app.dto.export_dto import ExportOptions
+from PySide6.QtWidgets import (
+    QComboBox,
+    QDialog,
+    QDialogButtonBox,
+    QDoubleSpinBox,
+    QFileDialog,
+    QFormLayout,
+    QHBoxLayout,
+    QLabel,
+    QLineEdit,
+    QPushButton,
+    QSpinBox,
+    QTimeEdit,
+    QVBoxLayout,
+    QWidget,
+)
+
+CODEC_PRESETS: list[tuple[str, str, str, int]] = [
+    # (label, codec, preset, default_crf)
+    ("H.264 — Fast (libx264, veryfast, CRF 23)", "libx264", "veryfast", 23),
+    ("H.264 — High Quality (libx264, slow, CRF 18)", "libx264", "slow", 18),
+    ("H.265 — Compatibility (libx265, medium, CRF 24)", "libx265", "medium", 24),
+    ("H.265 — High Quality (libx265, slow, CRF 20)", "libx265", "slow", 20),
+    ("VP9 — Web (libvpx-vp9, good, CRF 32)", "libvpx-vp9", "good", 32),
+]
+
+
+RESOLUTION_PRESETS: list[tuple[str, int | None, int | None]] = [
+    ("Project default", None, None),
+    ("3840 × 2160 (4K)", 3840, 2160),
+    ("1920 × 1080 (1080p)", 1920, 1080),
+    ("1280 × 720 (720p)", 1280, 720),
+    ("1080 × 1920 (Vertical 1080p)", 1080, 1920),
+    ("720 × 1280 (Vertical 720p)", 720, 1280),
+    ("1080 × 1080 (Square)", 1080, 1080),
+]
+
+
+FPS_PRESETS: list[tuple[str, float | None]] = [
+    ("Project default", None),
+    ("24 fps", 24.0),
+    ("25 fps", 25.0),
+    ("30 fps", 30.0),
+    ("50 fps", 50.0),
+    ("60 fps", 60.0),
+]
+
+
+def _seconds_to_qtime_args(seconds: float) -> tuple[int, int, int, int]:
+    seconds = max(0.0, float(seconds))
+    h = int(seconds // 3600)
+    rem = seconds - h * 3600
+    m = int(rem // 60)
+    rem -= m * 60
+    s = int(rem)
+    ms = int(round((rem - s) * 1000))
+    if ms >= 1000:
+        s += 1
+        ms = 0
+    return h, m, s, ms
+
+
+class ExportDialog(QDialog):
+    """User-facing knobs for exporting the active project.
+
+    Exposes:
+      * Output file picker.
+      * In/out point QTimeEdit (HH:mm:ss.zzz).
+      * Resolution preset (or custom width/height).
+      * FPS preset.
+      * Codec preset (H.264 fast/HQ, H.265, VP9).
+      * Live progress bar (driven externally via `set_progress` /
+        `set_progress_message`).
+    """
+
+    def __init__(
+        self,
+        project: Project,
+        suggested_output_path: str,
+        parent: QWidget | None = None,
+    ) -> None:
+        super().__init__(parent)
+        self.setWindowTitle("Export project")
+        self.setModal(True)
+        self.setMinimumWidth(520)
+
+        self._project = project
+        self._timeline_duration = max(project.timeline.total_duration(), 0.001)
+
+        root = QVBoxLayout(self)
+
+        # Output picker -------------------------------------------------
+        output_row = QHBoxLayout()
+        self._output_edit = QLineEdit(suggested_output_path, self)
+        browse_button = QPushButton("Browse…", self)
+        browse_button.clicked.connect(self._on_browse_clicked)
+        output_row.addWidget(QLabel("Output", self))
+        output_row.addWidget(self._output_edit, 1)
+        output_row.addWidget(browse_button)
+        root.addLayout(output_row)
+
+        # Form ---------------------------------------------------------
+        form = QFormLayout()
+        form.setFieldGrowthPolicy(QFormLayout.FieldGrowthPolicy.AllNonFixedFieldsGrow)
+
+        self._in_edit = QTimeEdit(self)
+        self._in_edit.setDisplayFormat("HH:mm:ss.zzz")
+        self._in_edit.setTime(self._in_edit.time().fromMSecsSinceStartOfDay(0))
+        form.addRow("In point", self._in_edit)
+
+        self._out_edit = QTimeEdit(self)
+        self._out_edit.setDisplayFormat("HH:mm:ss.zzz")
+        out_ms = int(round(self._timeline_duration * 1000))
+        self._out_edit.setTime(self._out_edit.time().fromMSecsSinceStartOfDay(out_ms))
+        form.addRow("Out point", self._out_edit)
+
+        self._resolution_combo = QComboBox(self)
+        for label, w, h in RESOLUTION_PRESETS:
+            self._resolution_combo.addItem(label, (w, h))
+        self._resolution_combo.currentIndexChanged.connect(self._on_resolution_preset_changed)
+        form.addRow("Resolution", self._resolution_combo)
+
+        custom_row = QHBoxLayout()
+        self._custom_width = QSpinBox(self)
+        self._custom_width.setRange(16, 7680)
+        self._custom_width.setValue(project.width)
+        self._custom_height = QSpinBox(self)
+        self._custom_height.setRange(16, 4320)
+        self._custom_height.setValue(project.height)
+        custom_row.addWidget(QLabel("W", self))
+        custom_row.addWidget(self._custom_width)
+        custom_row.addSpacing(8)
+        custom_row.addWidget(QLabel("H", self))
+        custom_row.addWidget(self._custom_height)
+        custom_row.addStretch(1)
+        form.addRow("Custom WxH", custom_row)
+
+        self._fps_combo = QComboBox(self)
+        for label, fps in FPS_PRESETS:
+            self._fps_combo.addItem(label, fps)
+        self._fps_combo.currentIndexChanged.connect(self._on_fps_preset_changed)
+        form.addRow("Frame rate", self._fps_combo)
+
+        self._fps_custom = QDoubleSpinBox(self)
+        self._fps_custom.setRange(1.0, 240.0)
+        self._fps_custom.setSingleStep(1.0)
+        self._fps_custom.setDecimals(3)
+        self._fps_custom.setValue(project.fps)
+        form.addRow("Custom fps", self._fps_custom)
+
+        self._codec_combo = QComboBox(self)
+        for label, codec, preset, crf in CODEC_PRESETS:
+            self._codec_combo.addItem(label, (codec, preset, crf))
+        form.addRow("Codec", self._codec_combo)
+
+        root.addLayout(form)
+
+        self._hint_label = QLabel(
+            "Export progress is reported in the status bar after the dialog closes.",
+            self,
+        )
+        self._hint_label.setWordWrap(True)
+        self._hint_label.setStyleSheet("color: #6d7684; font-size: 11px;")
+        root.addWidget(self._hint_label)
+
+        # Buttons ------------------------------------------------------
+        self._buttons = QDialogButtonBox(
+            QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel,
+            parent=self,
+        )
+        self._buttons.button(QDialogButtonBox.StandardButton.Ok).setText("Export")
+        self._buttons.accepted.connect(self.accept)
+        self._buttons.rejected.connect(self.reject)
+        root.addWidget(self._buttons)
+
+        # Reasonable defaults: jump to the project resolution preset if it
+        # matches one of the entries; otherwise fall back to "Project default".
+        for index in range(self._resolution_combo.count()):
+            data = self._resolution_combo.itemData(index)
+            if data == (project.width, project.height):
+                self._resolution_combo.setCurrentIndex(index)
+                break
+
+    # --- Public API used by callers ---------------------------------------
+    def output_path(self) -> str:
+        return self._output_edit.text().strip()
+
+    def export_options(self) -> ExportOptions:
+        in_ms = self._in_edit.time().msecsSinceStartOfDay()
+        out_ms = self._out_edit.time().msecsSinceStartOfDay()
+        in_seconds = in_ms / 1000.0
+        out_seconds = out_ms / 1000.0
+        if out_seconds <= in_seconds:
+            out_seconds = self._timeline_duration
+
+        # Resolution: prefer preset; fall back to custom WxH only when the
+        # custom values diverge from project defaults.
+        preset_data = self._resolution_combo.currentData()
+        if preset_data == (None, None):
+            width_override = (
+                self._custom_width.value()
+                if self._custom_width.value() != self._project.width
+                else None
+            )
+            height_override = (
+                self._custom_height.value()
+                if self._custom_height.value() != self._project.height
+                else None
+            )
+        else:
+            width_override, height_override = preset_data
+
+        # FPS: preset wins; otherwise look at the custom spinner.
+        fps_data = self._fps_combo.currentData()
+        if fps_data is None:
+            fps_override = (
+                self._fps_custom.value()
+                if abs(self._fps_custom.value() - self._project.fps) > 1e-3
+                else None
+            )
+        else:
+            fps_override = float(fps_data)
+
+        codec, preset, crf = self._codec_combo.currentData()
+
+        return ExportOptions(
+            in_point_seconds=in_seconds if in_seconds > 0 else None,
+            out_point_seconds=out_seconds if out_seconds < self._timeline_duration - 1e-3 else None,
+            width_override=width_override,
+            height_override=height_override,
+            fps_override=fps_override,
+            codec=codec,
+            preset=preset,
+            crf=crf,
+        )
+
+    # --- Internal handlers --------------------------------------------------
+    def _on_browse_clicked(self) -> None:
+        current = Path(self._output_edit.text().strip()) if self._output_edit.text().strip() else Path.cwd()
+        selected_path, _ = QFileDialog.getSaveFileName(
+            self,
+            "Choose export output file",
+            str(current),
+            "MP4 Video (*.mp4);;Matroska (*.mkv);;WebM (*.webm);;All Files (*.*)",
+        )
+        if selected_path:
+            self._output_edit.setText(selected_path)
+
+    def _on_resolution_preset_changed(self, _index: int) -> None:
+        data = self._resolution_combo.currentData()
+        if data == (None, None):
+            return
+        width, height = data
+        self._custom_width.blockSignals(True)
+        self._custom_height.blockSignals(True)
+        self._custom_width.setValue(int(width))
+        self._custom_height.setValue(int(height))
+        self._custom_width.blockSignals(False)
+        self._custom_height.blockSignals(False)
+
+    def _on_fps_preset_changed(self, _index: int) -> None:
+        data = self._fps_combo.currentData()
+        if data is None:
+            return
+        self._fps_custom.blockSignals(True)
+        self._fps_custom.setValue(float(data))
+        self._fps_custom.blockSignals(False)
+
+
+

