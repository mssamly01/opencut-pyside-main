+++ b/ui/preview/preview_widget.py
@@ -1,23 +1,448 @@
 from __future__ import annotations
 
+from dataclasses import dataclass
+from math import atan2, degrees
+
 from app.controllers.playback_controller import PlaybackController
+from app.controllers.project_controller import ProjectController
+from app.controllers.selection_controller import SelectionController
+from app.controllers.timeline_controller import TimelineController
+from app.domain.clips.base_clip import BaseClip
+from app.domain.clips.image_clip import ImageClip
+from app.domain.clips.text_clip import TextClip
+from app.domain.clips.video_clip import VideoClip
 from app.ui.preview.playback_toolbar import PlaybackToolbar
-from PySide6.QtCore import Qt
-from PySide6.QtGui import QImage, QPixmap, QResizeEvent
-from PySide6.QtWidgets import QLabel, QVBoxLayout, QWidget
+from PySide6.QtCore import QPoint, QPointF, QRect, QRectF, Qt
+from PySide6.QtGui import (
+    QColor,
+    QImage,
+    QMouseEvent,
+    QPainter,
+    QPaintEvent,
+    QPen,
+    QPixmap,
+    QResizeEvent,
+    QTransform,
+)
+from PySide6.QtWidgets import (
+    QCheckBox,
+    QHBoxLayout,
+    QPushButton,
+    QVBoxLayout,
+    QWidget,
+)
+
+_ASPECT_PRESETS: list[tuple[str, int, int]] = [
+    ("16:9", 1920, 1080),
+    ("9:16", 1080, 1920),
+    ("1:1", 1080, 1080),
+    ("4:3", 1440, 1080),
+    ("21:9", 2560, 1080),
+]
+
+
+_HANDLE_RADIUS = 6.0
+_ROTATION_HANDLE_OFFSET = 28.0
+_HANDLE_IDS = ("tl", "tr", "bl", "br", "rot")
+
+
+@dataclass
+class _DragState:
+    handle: str  # "body" | "tl" | "tr" | "bl" | "br" | "rot"
+    clip_id: str
+    start_widget_pos: QPointF
+    start_position_x: float
+    start_position_y: float
+    start_scale: float
+    start_rotation: float
+
+
+class PreviewCanvas(QWidget):
+    """Renders the current preview frame and an interactive manipulator overlay
+    (corner scale handles + rotation handle + body drag) for the currently
+    selected visual clip.
+    """
+
+    def __init__(
+        self,
+        project_controller: ProjectController,
+        timeline_controller: TimelineController,
+        selection_controller: SelectionController,
+        parent: QWidget | None = None,
+    ) -> None:
+        super().__init__(parent)
+        self._project_controller = project_controller
+        self._timeline_controller = timeline_controller
+        self._selection_controller = selection_controller
+
+        self.setMinimumHeight(240)
+        self.setObjectName("preview_canvas")
+        self.setMouseTracking(True)
+        self.setAutoFillBackground(True)
+
+        self._current_image: QImage | None = None
+        self._placeholder_text = "No frame"
+        self._show_safe_zone = True
+        self._drag_state: _DragState | None = None
+
+        self._selection_controller.selection_changed.connect(self.update)
+        self._timeline_controller.timeline_edited.connect(self.update)
+        self._project_controller.project_changed.connect(self.update)
+
+    # --- Public API ---------------------------------------------------
+    def set_preview_image(self, image: QImage | None) -> None:
+        self._current_image = image
+        self.update()
+
+    def set_placeholder_text(self, text: str) -> None:
+        self._placeholder_text = text
+        if self._current_image is None:
+            self.update()
+
+    def set_safe_zone_visible(self, visible: bool) -> None:
+        self._show_safe_zone = bool(visible)
+        self.update()
+
+    # --- Geometry helpers ---------------------------------------------
+    def _project_aspect(self) -> tuple[int, int]:
+        project = self._project_controller.active_project()
+        if project is None:
+            return (16, 9)
+        return (max(1, project.width), max(1, project.height))
+
+    def _project_rect(self) -> QRectF:
+        """Return the axis-aligned widget-space rect that represents the full
+        project frame (KeepAspectRatio fit within the widget).
+        """
+        canvas_rect = self.rect().adjusted(8, 8, -8, -8)
+        aw, ah = self._project_aspect()
+        if canvas_rect.width() <= 0 or canvas_rect.height() <= 0:
+            return QRectF(canvas_rect)
+        scale = min(canvas_rect.width() / aw, canvas_rect.height() / ah)
+        w = aw * scale
+        h = ah * scale
+        x = canvas_rect.left() + (canvas_rect.width() - w) / 2.0
+        y = canvas_rect.top() + (canvas_rect.height() - h) / 2.0
+        return QRectF(x, y, w, h)
+
+    def _selected_visual_clip(self) -> BaseClip | None:
+        project = self._project_controller.active_project()
+        if project is None:
+            return None
+        clip_id = self._selection_controller.selected_clip_id()
+        if clip_id is None:
+            return None
+        for track in project.timeline.tracks:
+            for clip in track.clips:
+                if clip.clip_id == clip_id and isinstance(clip, (VideoClip, ImageClip, TextClip)):
+                    return clip
+        return None
+
+    def _clip_bounds_rect(self, project_rect: QRectF, clip: BaseClip) -> QRectF:
+        """Axis-aligned local rect (centered at origin) for the clip bounds
+        before rotation is applied. TextClip uses a smaller indicator since
+        text typically doesn't fill the frame.
+        """
+        scale = float(getattr(clip, "scale", 1.0))
+        if isinstance(clip, TextClip):
+            base_w = project_rect.width() * 0.5
+            base_h = project_rect.height() * 0.2
+        else:
+            base_w = project_rect.width()
+            base_h = project_rect.height()
+        w = max(16.0, base_w * scale)
+        h = max(12.0, base_h * scale)
+        return QRectF(-w / 2.0, -h / 2.0, w, h)
+
+    def _clip_transform(self, project_rect: QRectF, clip: BaseClip) -> QTransform:
+        pos_x = getattr(clip, "position_x", 0.5)
+        pos_y = getattr(clip, "position_y", 0.5)
+        rotation = float(getattr(clip, "rotation", 0.0))
+        center_x = project_rect.left() + pos_x * project_rect.width()
+        center_y = project_rect.top() + pos_y * project_rect.height()
+        transform = QTransform()
+        transform.translate(center_x, center_y)
+        transform.rotate(rotation)
+        return transform
+
+    def _handle_positions(self, project_rect: QRectF, clip: BaseClip) -> dict[str, QPointF]:
+        bounds = self._clip_bounds_rect(project_rect, clip)
+        transform = self._clip_transform(project_rect, clip)
+        handles = {
+            "tl": transform.map(QPointF(bounds.left(), bounds.top())),
+            "tr": transform.map(QPointF(bounds.right(), bounds.top())),
+            "bl": transform.map(QPointF(bounds.left(), bounds.bottom())),
+            "br": transform.map(QPointF(bounds.right(), bounds.bottom())),
+            "rot": transform.map(QPointF(0.0, bounds.top() - _ROTATION_HANDLE_OFFSET)),
+        }
+        return handles
+
+    def _hit_test_handle(self, pos: QPointF, handles: dict[str, QPointF]) -> str | None:
+        for handle_id in _HANDLE_IDS:
+            if (pos - handles[handle_id]).manhattanLength() <= _HANDLE_RADIUS * 2.0:
+                return handle_id
+        return None
+
+    def _hit_test_body(self, pos: QPointF, project_rect: QRectF, clip: BaseClip) -> bool:
+        bounds = self._clip_bounds_rect(project_rect, clip)
+        transform = self._clip_transform(project_rect, clip)
+        inverse, ok = transform.inverted()
+        if not ok:
+            return False
+        local = inverse.map(pos)
+        return bounds.contains(local)
+
+    # --- Qt overrides -------------------------------------------------
+    def resizeEvent(self, event: QResizeEvent) -> None:
+        super().resizeEvent(event)
+        self.update()
+
+    def paintEvent(self, event: QPaintEvent) -> None:  # noqa: ARG002
+        painter = QPainter(self)
+        painter.setRenderHint(QPainter.RenderHint.Antialiasing, True)
+        painter.fillRect(self.rect(), QColor("#050709"))
+
+        project_rect = self._project_rect()
+
+        # Canvas frame: dark fill + subtle border.
+        painter.fillRect(project_rect, QColor("#11161c"))
+        border_pen = QPen(QColor("#2b323c"))
+        border_pen.setWidth(1)
+        painter.setPen(border_pen)
+        painter.setBrush(Qt.BrushStyle.NoBrush)
+        painter.drawRect(project_rect)
+
+        # Draw the preview frame image (if any).
+        if self._current_image is not None and not self._current_image.isNull():
+            pixmap = QPixmap.fromImage(self._current_image)
+            target = project_rect.toRect()
+            scaled = pixmap.scaled(
+                target.size(),
+                Qt.AspectRatioMode.KeepAspectRatio,
+                Qt.TransformationMode.SmoothTransformation,
+            )
+            dx = target.left() + (target.width() - scaled.width()) // 2
+            dy = target.top() + (target.height() - scaled.height()) // 2
+            painter.drawPixmap(QPoint(dx, dy), scaled)
+        else:
+            painter.setPen(QColor("#6b7280"))
+            painter.drawText(project_rect, Qt.AlignmentFlag.AlignCenter, self._placeholder_text)
+
+        # Safe-zone guide (90% centered, dashed).
+        if self._show_safe_zone:
+            margin_x = project_rect.width() * 0.05
+            margin_y = project_rect.height() * 0.05
+            safe_rect = project_rect.adjusted(margin_x, margin_y, -margin_x, -margin_y)
+            safe_pen = QPen(QColor(120, 150, 200, 160))
+            safe_pen.setStyle(Qt.PenStyle.DashLine)
+            safe_pen.setWidthF(1.0)
+            painter.setPen(safe_pen)
+            painter.setBrush(Qt.BrushStyle.NoBrush)
+            painter.drawRect(safe_rect)
+
+        # Manipulator overlay for selected clip.
+        clip = self._selected_visual_clip()
+        if clip is not None and project_rect.width() > 0:
+            self._paint_manipulator(painter, project_rect, clip)
+
+        painter.end()
+
+    def _paint_manipulator(self, painter: QPainter, project_rect: QRectF, clip: BaseClip) -> None:
+        painter.save()
+        bounds = self._clip_bounds_rect(project_rect, clip)
+        transform = self._clip_transform(project_rect, clip)
+        painter.setTransform(transform, combine=True)
+
+        pen = QPen(QColor("#f6c453"))
+        pen.setWidthF(1.4)
+        pen.setStyle(Qt.PenStyle.SolidLine)
+        painter.setPen(pen)
+        painter.setBrush(QColor(246, 196, 83, 30))
+        painter.drawRect(bounds)
+
+        # Rotation stem from top-center up to the rotation handle.
+        stem_top = QPointF(0.0, bounds.top() - _ROTATION_HANDLE_OFFSET)
+        painter.drawLine(QPointF(0.0, bounds.top()), stem_top)
+        painter.restore()
+
+        handles = self._handle_positions(project_rect, clip)
+        painter.setPen(QPen(QColor("#111418"), 1.2))
+        painter.setBrush(QColor("#f6c453"))
+        for handle_id, point in handles.items():
+            r = _HANDLE_RADIUS
+            if handle_id == "rot":
+                painter.setBrush(QColor("#9cd38c"))
+                painter.drawEllipse(point, r, r)
+                painter.setBrush(QColor("#f6c453"))
+            else:
+                painter.drawRect(QRectF(point.x() - r, point.y() - r, 2 * r, 2 * r))
+
+    # --- Mouse interactions -------------------------------------------
+    def mousePressEvent(self, event: QMouseEvent) -> None:
+        if event.button() != Qt.MouseButton.LeftButton:
+            super().mousePressEvent(event)
+            return
+        clip = self._selected_visual_clip()
+        if clip is None:
+            super().mousePressEvent(event)
+            return
+        project_rect = self._project_rect()
+        if project_rect.width() <= 0:
+            return
+        pos = event.position()
+        handles = self._handle_positions(project_rect, clip)
+        handle = self._hit_test_handle(pos, handles)
+        if handle is None and self._hit_test_body(pos, project_rect, clip):
+            handle = "body"
+        if handle is None:
+            super().mousePressEvent(event)
+            return
+        self._drag_state = _DragState(
+            handle=handle,
+            clip_id=clip.clip_id,
+            start_widget_pos=QPointF(pos),
+            start_position_x=getattr(clip, "position_x", 0.5),
+            start_position_y=getattr(clip, "position_y", 0.5),
+            start_scale=float(getattr(clip, "scale", 1.0)),
+            start_rotation=float(getattr(clip, "rotation", 0.0)),
+        )
+        event.accept()
+
+    def mouseMoveEvent(self, event: QMouseEvent) -> None:
+        state = self._drag_state
+        if state is None:
+            super().mouseMoveEvent(event)
+            return
+        project_rect = self._project_rect()
+        if project_rect.width() <= 0:
+            return
+        clip = self._selected_visual_clip()
+        if clip is None or clip.clip_id != state.clip_id:
+            self._drag_state = None
+            return
+
+        pos = event.position()
+        if state.handle == "body":
+            dx = (pos.x() - state.start_widget_pos.x()) / project_rect.width()
+            dy = (pos.y() - state.start_widget_pos.y()) / project_rect.height()
+            new_x = max(0.0, min(1.0, state.start_position_x + dx))
+            new_y = max(0.0, min(1.0, state.start_position_y + dy))
+            self._apply_clip_update(clip, position_x=new_x, position_y=new_y)
+        elif state.handle == "rot":
+            center_x = project_rect.left() + state.start_position_x * project_rect.width()
+            center_y = project_rect.top() + state.start_position_y * project_rect.height()
+            start_angle = degrees(
+                atan2(state.start_widget_pos.y() - center_y, state.start_widget_pos.x() - center_x)
+            )
+            current_angle = degrees(atan2(pos.y() - center_y, pos.x() - center_x))
+            new_rotation = state.start_rotation + (current_angle - start_angle)
+            self._apply_clip_update(clip, rotation=new_rotation)
+        else:
+            # Corner scale: grow/shrink uniformly based on radial distance
+            # from clip center.
+            center_x = project_rect.left() + state.start_position_x * project_rect.width()
+            center_y = project_rect.top() + state.start_position_y * project_rect.height()
+            start_dist = (
+                (state.start_widget_pos.x() - center_x) ** 2
+                + (state.start_widget_pos.y() - center_y) ** 2
+            ) ** 0.5
+            current_dist = ((pos.x() - center_x) ** 2 + (pos.y() - center_y) ** 2) ** 0.5
+            if start_dist <= 1.0:
+                return
+            ratio = current_dist / start_dist
+            new_scale = max(0.05, min(6.0, state.start_scale * ratio))
+            self._apply_clip_update(clip, scale=new_scale)
+
+        event.accept()
